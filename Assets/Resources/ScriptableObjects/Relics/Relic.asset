    displayIcon: {fileID: 21300000, guid: 1a8eb3e145531ef42b780cbb0a81b8ba, type: 3}
    displayName: "\uB85C\uCEEC \uD14C\uC2A4\uD2B8 \uC720\uBB3C \uC608\uC2DC"
    displayDescription: "<color=#FFD700><b>[\uC720\uBB3C \uD3B8\uC9D1 \uBC0F \uC0DD\uC131
      \uAC00\uC774\uB4DC]</b></color>\n\n<color=#81FF17><b>1. \uB370\uC774\uD130
      \uC124\uC815 (Definition)</b></color>\n\uC778\uC2A4\uD399\uD130\uC758 <b>'Score
      Settings'</b>\uC640 <b>'Properties'</b> \uD56D\uBAA9\uB9CC \uC218\uC815\uD558\uC138\uC694.
      \uC774\uACF3\uC5D0 \uC785\uB825\uD55C \uC218\uCE58\uB294 \uAC8C\uC784 \uB85C\uC9C1\uC5D0
      \uC989\uC2DC \uBC18\uC601\uB418\uBA70, \uBCC4\uB3C4\uC758 \uCF54\uB529 \uC5C6\uC774
      \uC720\uBB3C\uC758 \uBC38\uB7F0\uC2A4\uB97C \uC870\uC808\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n<color=#81FF17><b>2.
      \uC2E4\uC2DC\uAC04 \uC124\uBA85 \uBBF8\uB9AC\uBCF4\uAE30</b></color>\n\uC124\uBA85
      \uCE78\uC5D0 \uC9C1\uC811 \uD14D\uC2A4\uD2B8\uB97C \uC801\uC9C0 \uC54A\uC544\uB3C4,
      \uC124\uC815\uD55C <color=#FFFFFF>\uC218\uCE58(Value, Target)</color>\uC5D0
      \uB530\uB77C \uD558\uB2E8 <color=#CECECE><i>Description</i></color> \uB77C\uBCA8\uC774
      \uC2E4\uC2DC\uAC04\uC73C\uB85C \uAC31\uC2E0\uB429\uB2C8\uB2E4. \uC720\uC800\uC5D0\uAC8C
      \uBCF4\uC5EC\uC9C8 \uCD5C\uC885 \uBB38\uAD6C\uB97C \uC5D0\uB514\uD130\uC5D0\uC11C
      \uC989\uC2DC \uD655\uC778\uD558\uC138\uC694.\n\n<color=#81FF17><b>3. \uD6A8\uACFC(Effect)
      \uCD94\uAC00 \uBC0F \uAD00\uB9AC</b></color>\n<color=#FFFFFF>'Add Effect'</color>
      \uBC84\uD2BC\uC744 \uB20C\uB7EC \uC6D0\uD558\uB294 \uD6A8\uACFC\uB97C \uCE74\uD14C\uACE0\uB9AC\uBCC4\uB85C
      \uC120\uD0DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
